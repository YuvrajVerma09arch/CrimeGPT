# .env.example — copy to .env and fill in

# Database
# Default (no Docker needed): SQLite for instant local demo
DATABASE_URL=sqlite+aiosqlite:///./crimegpt.db
# Docker / production: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://crimegpt:your_postgres_password@localhost:5432/crimegpt
DB_PASSWORD=your_postgres_password

# Auth
JWT_SECRET=change_me_super_secret_jwt_key_min_32_chars!!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI (optional — for embeddings + narrative summarization;
# without it, ChromaDB's built-in local embeddings are used)
OPENAI_API_KEY=

# Translation (optional — falls back to passthrough if unset)
TRANSLATION_SERVICE_URL=http://localhost:8001
GOOGLE_TRANSLATE_API_KEY=

# Storage
UPLOAD_DIR=./uploads
CHROMA_DB_PATH=./chroma_db

# Redis (optional — only needed for Celery async doc generation)
REDIS_URL=redis://localhost:6379
USE_CELERY=false

# OCR (optional)
GOOGLE_VISION_API_KEY=

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173
